# ─────────────────────────────────────────────────────────────────────────────
#  TTS ENGINE  —  uncomment exactly one
# ─────────────────────────────────────────────────────────────────────────────
#TTS_ENGINE=elevenlabs          # ⚡ Best quality  (~0.7s/line)
#TTS_ENGINE=openai_tts         # 🔵 Great quality (~1.0s/line)
#TTS_ENGINE=amazon_polly       # 🟠 Low latency   (~0.5s/line) — pip install boto3
TTS_ENGINE=gtts               # 🟢 Free, no key  (~1.5s/line) — pip install gtts

# ─────────────────────────────────────────────────────────────────────────────
#  ElevenLabs  (https://elevenlabs.io → Profile → API Key)
# ─────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Other models: eleven_turbo_v2  |  eleven_turbo_v2_5  |  eleven_monolingual_v1

# ─────────────────────────────────────────────────────────────────────────────
#  OpenAI TTS  (https://platform.openai.com/api-keys)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Other models: tts-1-hd  (slower but higher quality)

# ─────────────────────────────────────────────────────────────────────────────
#  Amazon Polly  (IAM user with AmazonPollyFullAccess policy)
# ─────────────────────────────────────────────────────────────────────────────
POLLY_ENGINE=neural
# Other engine: standard  (more voices, lower quality)

# ─────────────────────────────────────────────────────────────────────────────
#  gTTS  (no key needed — free Google Translate TTS)
# ─────────────────────────────────────────────────────────────────────────────
GTTS_SLOW=false
# Set to true for slower, clearer speech (useful for language learning)
